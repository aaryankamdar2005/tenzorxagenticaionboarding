# Frontend API & WebSocket URLs
# During Docker build, these arguments MUST be passed in. 
# Example Deployment (replace with your server's public IP or Domain)
# NEXT_PUBLIC_API_URL=https://api.yourbank.com
# NEXT_PUBLIC_WS_URL=wss://api.yourbank.com

NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
